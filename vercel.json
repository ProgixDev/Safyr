{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "bun install --no-frozen-lockfile",
  "buildCommand": "cd packages/schemas && bun run build && cd ../../apps/server && bunx prisma generate && bunx prisma db push --accept-data-loss && bunx nest build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "{apps/server/dist,apps/server/generated,packages/schemas/dist}/**"
    }
  }
}
