# Copy this file to .env.local and fill in values

# Safyr API base URL (NestJS server)
NEXT_PUBLIC_API_URL=http://localhost:4000


# Safyr web app public origin
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapbox public access token — required for the live geolocation map
# Get yours at https://account.mapbox.com/ (free tier is sufficient)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_token_here
