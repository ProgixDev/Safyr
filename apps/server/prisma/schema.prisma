// Safyr Prisma schema.
// Models are generated by `bun run auth:generate` (better-auth CLI) + hand-written Safyr extensions.
// Run `bun run db:migrate` to apply changes.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String       @id
  name             String
  email            String
  emailVerified    Boolean      @default(false)
  image            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  role             String?
  banned           Boolean?     @default(false)
  banReason        String?
  banExpires       DateTime?
  username         String?
  displayUsername  String?
  twoFactorEnabled Boolean?     @default(false)
  sessions         Session[]
  accounts         Account[]
  members          Member[]
  invitations      Invitation[]
  twofactors       TwoFactor[]
  documents        Document[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  impersonatedBy       String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Representative {
  id                   String    @id @default(cuid())
  firstName            String
  lastName             String
  birthDate            DateTime?
  birthPlace           String?
  nationality          String?
  address              String?
  email                String?
  phone                String?
  position             String?
  appointmentDate      DateTime?
  socialSecurityNumber String?

  organization Organization?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("representative")
}

model Organization {
  id        String   @id
  name      String
  slug      String
  logo      String?
  createdAt DateTime
  metadata  String?
  siret     String?
  ape       String?
  address   String?

  // Company Info
  shareCapital        String?
  authorizationNumber String?
  email               String?
  phone               String?

  representativeId String?         @unique
  representative   Representative? @relation(fields: [representativeId], references: [id], onDelete: SetNull)

  members     Member[]
  invitations Invitation[]
  documents   Document[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("owner")
  createdAt      DateTime

  // --- HR Additional Fields ---
  firstName            String?
  lastName             String?
  email                String?
  phone                String?
  birthDate            DateTime?
  birthPlace           String?
  nationality          String?
  address              String?
  position             String?
  appointmentDate      DateTime?
  socialSecurityNumber String?

  // --- Employment ---
  employeeNumber String?
  hireDate       DateTime?
  contractType   String?
  workSchedule   String?
  status         String  @default("active")
  gender         String?
  civilStatus    String?
  children       Int?
  terminatedAt   DateTime?

  documents      Document[]
  addressRecord  MemberAddress?
  bankDetails    MemberBankDetails?
  certifications Certification[]
  timeEntries    TimeEntry[]
  logbookEvents  LogbookEvent[]

  @@unique([organizationId, employeeNumber])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model MemberAddress {
  id         String  @id @default(cuid())
  memberId   String  @unique
  member     Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  street     String
  city       String
  postalCode String
  country    String  @default("France")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("member_address")
}

model MemberBankDetails {
  id       String @id @default(cuid())
  memberId String @unique
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  iban     String
  bic      String
  bankName String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("member_bank_details")
}

model Certification {
  id         String    @id @default(cuid())
  memberId   String
  member     Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type       String // CQP_APS | CNAPS | SSIAP1 | SSIAP2 | SSIAP3 | SST | VM | H0B0 | FIRE
  number     String
  issuer     String
  issueDate  DateTime
  expiryDate DateTime
  verified   Boolean   @default(false)
  status     String    @default("valid") // "valid" | "expiring" | "expired" | "pending-renewal"
  documentId String?   @unique
  document   Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@map("certification")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verified    Boolean? @default(true)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model DocumentRequirement {
  id          String   @id @default(cuid())
  name        String // e.g., "Kbis", "Carte pro CNAPS"
  description String?
  type        String // e.g., "kbis", "carte_pro_dirigeant"
  category    String // e.g., "entreprise", "dirigeant"

  targetType String // "ORGANIZATION", "MEMBER", "CLIENT", etc.

  isRequired Boolean @default(false)
  hasExpiry  Boolean @default(false)

  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, targetType])
  @@map("document_requirement")
}

model Document {
  id         String @id @default(cuid())
  name       String
  storageKey String @unique
  mimeType   String
  size       Int

  status     String    @default("valid") // "valid" | "expiring" | "expired" | "rejected"
  expiryDate DateTime?

  requirementId String?
  requirement   DocumentRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: Cascade)

  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id])

  certification Certification?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, requirementId])
  @@index([organizationId])
  @@index([memberId])
  @@index([uploaderId])
  @@index([requirementId])
  @@map("document")
}

model TimeEntry {
  id             String @id @default(cuid())
  organizationId String
  memberId       String
  member         Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  siteName  String?
  source    String   @default("gps") // "gps" | "qr" | "manual"

  clockInAt  DateTime
  clockInLat Float?
  clockInLng Float?

  clockOutAt  DateTime?
  clockOutLat Float?
  clockOutLng Float?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([memberId])
  @@index([organizationId, clockInAt])
  @@map("time_entry")
}

model Site {
  id             String @id @default(cuid())
  organizationId String

  name        String
  clientName  String?
  address     String?
  city        String?
  postalCode  String?
  country     String  @default("France")
  latitude    Float?
  longitude   Float?
  geofenceRadiusMeters Int?

  notes  String?
  active Boolean @default(true)

  posts        Post[]
  logbookEvents LogbookEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("site")
}

model Post {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  name                  String
  description           String?
  requiredCertifications String[] @default([])
  defaultStartTime      String? // "07:00"
  defaultEndTime        String? // "19:00"
  active                Boolean  @default(true)

  shifts Shift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, name])
  @@index([siteId])
  @@map("post")
}

model Shift {
  id             String @id @default(cuid())
  organizationId String

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Optionnel: l'agent affecté (null = à pourvoir)
  memberId String?

  startAt DateTime
  endAt   DateTime

  status String  @default("planned") // "planned" | "confirmed" | "cancelled" | "completed"
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([postId])
  @@index([memberId])
  @@index([organizationId, startAt])
  @@map("shift")
}

model LogbookEvent {
  id             String @id @default(cuid())
  organizationId String

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  type     String // "event" | "incident" | "action" | "control"
  category String? // "intrusion" | "fire" | "patrol" | "visitor" | ...
  severity String   @default("low") // "low" | "medium" | "high" | "critical"
  title    String
  description String?

  occurredAt DateTime @default(now())
  latitude   Float?
  longitude  Float?

  status      String   @default("open") // "open" | "validated" | "closed" | "rejected"
  validatorId String?
  validatedAt DateTime?
  validationComment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([memberId])
  @@index([siteId])
  @@index([organizationId, occurredAt])
  @@map("logbook_event")
}

